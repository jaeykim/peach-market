generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 사용자 (매도자/매수자 모두)
model User {
  id         String    @id @default(cuid())
  email      String    @unique
  password   String
  name       String
  phone      String?
  verifiedAt     DateTime? // 본인 인증 (PASS/NICE 시뮬레이션) 완료 시각
  residentNumber String?   // 주민등록번호 (실서비스에서는 암호화 저장 필수)
  address        String?   // 주민등록상 주소
  createdAt      DateTime  @default(now())

  // 공인중개사 (브로커) 정보
  isBroker      Boolean @default(false)
  brokerLicense String? // 자격증 번호
  brokerOffice  String? // 사무소명
  brokerRegion  String? // 활동 지역

  listings Listing[]
  bids     Bid[]
  dealsAsBuyer  Deal[] @relation("DealBuyer")
  dealsAsSeller Deal[] @relation("DealSeller")

  notifications Notification[]
  chatMessages  ChatMessage[]
  favorites     Favorite[]
  recentViews   RecentView[]
  brokerDeals   Deal[]         @relation("DealBroker")
}

// 매물 (매도/매수 양쪽 등록 가능)
model Listing {
  id          String   @id @default(cuid())
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id])

  // 등록 유형: SELL = 공급자(매도/임대/전대), BUY = 수요자(매수/임차/전차)
  side        String   // "SELL" | "BUY"
  // 임대 매물에서 전대(sublet) 여부
  isSublet    Boolean  @default(false)
  // 단기임대 여부 (방학 단기, 인턴십 등)
  isShortTerm Boolean  @default(false)
  // 임대 기간 (개월 수, 단기임대일 때 주로 사용)
  rentalMonths Int?

  // 위치
  address     String   // 도로명/지번 주소
  addressDetail String?
  lat         Float
  lng         Float

  // 매물 정보
  title       String
  propertyType String  // APT/OFFICETEL/HOUSE/...
  areaExclusive Float? // 전용면적 (㎡)
  areaSupply  Float?   // 공급면적
  floor       Int?
  totalFloors Int?
  direction   String?
  builtYear   Int?
  rooms       Int?
  bathrooms   Int?
  maintenanceFee Int?

  // 가격 (단위: 만원)
  askingPrice Int      // 매매가/전세금/월세(월) - dealType에 따라 의미 다름
  // BUY 매물(매수 희망)에서 가격 범위 표현용. 둘 다 있으면 X~Y, min만 X 이상, max만 X 이하
  priceMin    Int?
  priceMax    Int?
  deposit     Int?     // 보증금 (월세의 경우 별도; 전세는 askingPrice가 곧 전세금이므로 null 가능)
  dealType    String   // SALE/JEONSE/MONTHLY

  description String?
  photos      String?  // JSON array of URLs

  status      String   @default("OPEN") // OPEN/IN_NEGOTIATION/CLOSED

  viewCount   Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bids        Bid[]
  deals       Deal[]
  favorites   Favorite[]
  recentViews RecentView[]
}

// 비공개 비드 (당사자 외 비공개)
model Bid {
  id          String   @id @default(cuid())
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id])
  // 비드 제안자 (반대 측 사용자)
  proposerId  String
  proposer    User     @relation(fields: [proposerId], references: [id])

  amount      Int      // 단위: 만원
  message     String?

  // PENDING/ACCEPTED/REJECTED/COUNTERED/WITHDRAWN
  status      String   @default("PENDING")

  // 카운터오퍼 체인
  parentBidId String?
  parent      Bid?     @relation("BidCounter", fields: [parentBidId], references: [id])
  counters    Bid[]    @relation("BidCounter")

  createdAt   DateTime @default(now())
}

// 딜 성사
model Deal {
  id          String   @id @default(cuid())
  listingId   String
  listing     Listing  @relation(fields: [listingId], references: [id])
  buyerId     String
  buyer       User     @relation("DealBuyer", fields: [buyerId], references: [id])
  sellerId    String
  seller      User     @relation("DealSeller", fields: [sellerId], references: [id])

  agreedPrice Int      // 단위: 만원

  // 가계약금 (단위: 만원)
  earnestMoney            Int?
  earnestMoneyStatus      String?  // PENDING / PAID / CONFIRMED / REFUNDED
  earnestMoneyPaidAt      DateTime?
  earnestMoneyConfirmedAt DateTime?

  // 검토·서명 담당 공인중개사 (선택사항)
  brokerId    String?
  broker      User?    @relation("DealBroker", fields: [brokerId], references: [id])
  brokerStatus String? // PENDING_REVIEW / APPROVED / REJECTED

  // 계약 준비 정보 (JSON으로 저장)
  contractData String? // JSON: 잔금일정, 특약 등

  status      String   @default("AGREED") // AGREED/CONTRACT_READY/COMPLETED/CANCELLED

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  chatMessages ChatMessage[]
}

// 알림
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // BID_RECEIVED / BID_ACCEPTED / BID_REJECTED / COUNTER_RECEIVED / DEAL_CLOSED / CHAT_MESSAGE
  payload   String   // JSON
  readAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// 딜 채팅
model ChatMessage {
  id        String   @id @default(cuid())
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id])
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])
  text      String
  createdAt DateTime @default(now())

  @@index([dealId, createdAt])
}

// 찜
model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
}

// 최근 본 매물
model RecentView {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id])
  viewedAt  DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId, viewedAt])
}
